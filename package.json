{
  "name": "simple-liquid-glass",
  "version": "4.0.0",
  "type": "module",
  "description": "Zero-dependency React liquid glass with real SVG-displacement refraction on Chromium/Edge/Android-Chrome (a polished frosted-glass fallback on Safari/iOS/Firefox). Directional + animated 'liquid' refraction, lens modes. SSR-safe, ~10KB (web component ~6KB), React 16.8–19. Web-component included.",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./interactive": {
      "types": "./dist/interactive.d.ts",
      "import": "./dist/interactive.esm.js",
      "require": "./dist/interactive.cjs"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.esm.js",
      "require": "./dist/web-component.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt",
    "skills"
  ],
  "scripts": {
    "build": "rollup -c && node scripts/copy-types.mjs",
    "dev": "rollup -c -w",
    "test": "jest",
    "size": "size-limit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "size-limit": [
    {
      "name": "core — import { LiquidGlass } (gzip)",
      "path": "dist/index.esm.js",
      "limit": "10.5 KB",
      "ignore": ["react", "react-dom"]
    },
    {
      "name": "interactive — import { LiquidGlassInteractive } (gzip, bundles core)",
      "path": "dist/interactive.esm.js",
      "limit": "12.5 KB",
      "ignore": ["react", "react-dom"]
    },
    {
      "name": "web-component — <liquid-glass> (gzip, no React)",
      "path": "dist/web-component.esm.js",
      "limit": "6.5 KB"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucaperullo/simple-liquid-glass.git"
  },
  "keywords": [
    "liquid-glass",
    "liquid-glass-react",
    "react-liquid-glass",
    "apple-liquid-glass",
    "ios-glass",
    "ios-26",
    "safari-glass",
    "firefox-glass",
    "cross-browser",
    "webkit",
    "glassmorphism",
    "glass-morphism",
    "glassmorphism-react",
    "frosted-glass",
    "glass-effect",
    "refraction",
    "displacement-map",
    "chromatic-aberration",
    "backdrop-filter",
    "svg-filter",
    "web-component",
    "custom-element",
    "interactive",
    "pointer-elasticity",
    "ssr",
    "server-side-rendering",
    "nextjs",
    "lightweight",
    "zero-dependencies",
    "tiny",
    "accessibility",
    "a11y",
    "react",
    "react-16",
    "react-17",
    "react-18",
    "react-19",
    "glass-ui",
    "glass-card",
    "glass-panel",
    "apple-design"
  ],
  "author": "lucaperullo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lucaperullo/simple-liquid-glass/issues"
  },
  "homepage": "https://simple-liquid-glass.vercel.app/",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "tar": "^7.5.16",
    "uuid": "^11.1.1",
    "esbuild": "^0.28.1"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.27.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/react": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^29.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.4",
    "vite": "^8.0.0"
  }
}
